rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdminOrDev() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['dev', 'admin'];
    }

    function isDev() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dev';
    }

    // กฎสำหรับ requester collection - ผู้ใช้ใหม่ที่รอการอนุมัติ
    match /requester/{userId} {
      allow create: if isOwner(userId);
      allow read: if isOwner(userId) || isAdminOrDev();
      allow delete: if isAdminOrDev();
      allow update: if false;
    }

    // กฎสำหรับ Collection หลัก (users) และ Subcollection ทั้งหมด
    match /users/{userId} {
      // เจ้าของ doc อ่าน/เขียนได้เอง
      allow read, write: if isOwner(userId);
      // dev จัดการได้ทุกคน (ยกเว้นตัวเอง จัดการฝั่ง client)
      allow read, create, update, delete: if isDev();
      // admin อ่านได้ทุกคน, แก้ไข/ลบได้เฉพาะ user ที่ไม่ใช่ dev/admin
      allow read: if isAdminOrDev();
      allow update, delete: if isAdminOrDev()
        && resource.data.role == 'user';

      // subcollections (transactions, budgets, categories)
      match /{document=**} {
        allow read, write: if isOwner(userId);
        allow read, create, update, delete: if isAdminOrDev();
      }
    }

    // ป้องกันการเข้าถึง Collection อื่นๆ
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
