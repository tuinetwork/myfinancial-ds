rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      let data = getUserData();
      return isAuthenticated() && data.role == 'admin';
    }

    function isDev() {
      let data = getUserData();
      return isAuthenticated() && data.role == 'dev';
    }

    // --- VALIDATION FUNCTIONS (The 10/10 Secret Sauce) ---

    function isValidNumber(value) {
      return value is number;
    }

    function isValidString(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function isUnchanged(field) {
      return isDev() || !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    function isServerTimestamp(field) {
      return isDev() || request.resource.data[field] == request.time;
    }

    function isOneOf(value, list) {
      return value in list;
    }

    // --- RULES ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isDev() || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && isUnchanged('role') && resource.data.role == 'user')
                    || isDev()
                    || (isAdmin() && isUnchanged('role'));
      allow write, delete: if isDev();

      // 1. Accounts
      match /accounts/{accountId} {
        allow read: if isOwner(userId) || isDev();
        allow delete: if isOwner(userId) || isDev();
        allow write: if (isOwner(userId) || isDev())
                     && isValidNumber(request.resource.data.balance)
                     && isValidString(request.resource.data.name, 1, 50)
                     && isOneOf(request.resource.data.type, ['cash', 'bank', 'savings', 'investment', 'credit_card', 'loan', 'receivable', 'payable', 'inventory'])
                     && (request.method == 'create' || isUnchanged('created_at'));
      }

      // 2. Transactions
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isDev();
        allow delete: if isOwner(userId) || isDev();
        allow write: if (isOwner(userId) || isDev())
                     && isValidNumber(request.resource.data.amount)
                     && request.resource.data.amount >= 0
                     && isOneOf(request.resource.data.type, ['income', 'expense', 'transfer'])
                     && (request.method == 'create' || isUnchanged('created_at'));
      }

      // 3. Investments
      match /investments/{investmentId} {
        allow read: if isOwner(userId) || isDev();
        allow write: if (isOwner(userId) || isDev())
                     && isValidNumber(request.resource.data.total_units)
                     && isValidNumber(request.resource.data.current_market_price)
                     && isOneOf(request.resource.data.asset_class, ['stock', 'mutual_fund', 'crypto', 'bond', 'loan', 'business', 'inventory']);
      }

      // 4. Goals
      match /goals/{goalId} {
        allow read: if isOwner(userId) || isDev();
        allow write: if (isOwner(userId) || isDev())
                     && isValidNumber(request.resource.data.target_amount)
                     && isOneOf(request.resource.data.status, ['active', 'completed', 'cancelled']);
      }

      // 5. Budgets
      match /budgets/{budgetId} {
        allow read: if isOwner(userId) || isDev();
        allow write: if isOwner(userId) || isDev();
      }

      // 6. Categories
      match /categories/{categoryId} {
        allow read: if isOwner(userId) || isDev();
        allow write: if isOwner(userId) || isDev();
      }

      // catch-all: read-only — ป้องกันไม่ให้ bypass validation rules ด้านบน
      // หากต้องการทำ Big Migration ให้ปลดคอมเมนต์ write ของ isDev() ชั่วคราว
      match /{document=**} {
        allow read: if isOwner(userId) || isDev();
        // allow write: if isDev(); // <--- ปลดคอมเมนต์เมื่อจะทำ Big Migration เท่านั้น
      }
    }

    match /requester/{userId} {
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow read: if isOwner(userId) || isDev() || isAdmin();
      allow delete: if isDev() || isAdmin();
      allow update: if isAdmin() || isDev();
    }

    // shared_reports — token-gated read (get only, no listing), owner write/delete
    match /shared_reports/{token} {
      allow get: if true;   // ใครมี token อ่านได้ แต่ list/query ทั้ง collection ไม่ได้
      allow list: if isDev();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isDev();
    }

    // system_config — ทุกคนอ่านได้ (maintenance/broadcast/force_refresh), dev เขียนได้
    match /system_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isDev();
    }

    match /{path=**} {
      allow read, write: if false;
    }

  }
}
