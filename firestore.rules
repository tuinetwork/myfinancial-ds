rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // ฟังก์ชันช่วยตรวจสอบว่าผู้ใช้ล็อกอินอยู่หรือไม่
    function isAuthenticated() {
      return request.auth != null;
    }

    // ฟังก์ชันช่วยตรวจสอบว่าผู้ใช้ที่กำลังใช้งาน เป็นเจ้าของข้อมูลนี้จริงๆ (เทียบ UID)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // กฎสำหรับ Collection หลัก (users) และ Subcollection ทั้งหมดที่อยู่ข้างใน
    match /users/{userId} {

      // อนุญาตให้อ่านและเขียน Document Profile ของตัวเองได้
      allow read, write: if isOwner(userId);

      // กฎสำหรับ transactions - เพิ่ม input validation ฝั่ง server
      match /transactions/{txId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.amount < 10000000
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 500
          && request.resource.data.date is string
          && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && request.resource.data.type in ['expense', 'income']
          && request.resource.data.main_category is string
          && request.resource.data.sub_category is string;
        allow update, delete: if isOwner(userId);
      }

      // กฎสำหรับ Subcollection อื่นๆ (categories, budgets)
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // ป้องกันการเข้าถึง Collection อื่นๆ ที่ไม่ได้ตั้งค่าไว้ (ปิดตายเพื่อความปลอดภัย)
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
